{
    "name": "svader-monorepo",
    "private": true,
    "type": "module",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "package": "cd packages/svader && npm run package",
        "dev:logo": "npm run package && cd packages/logo && npm run dev",
        "dev:test-site": "npm run package && cd packages/test-site && npm run dev",
        "preview:logo": "cd packages/logo && npm run preview",
        "preview:test-site": "cd packages/test-site && npm run preview",
        "check": "npm run package && npm run check:formatting && npm run check:lint && npm run check:svader && npm run check:logo && npm run check:test-site",
        "check:formatting": "prettier . --check",
        "check:lint": "eslint .",
        "check:svader": "cd packages/svader && npm run check",
        "check:logo": "cd packages/logo && npm run check",
        "check:test-site": "cd packages/test-site && npm run check",
        "build": "npm run package && npm run build:logo && npm run build:test-site",
        "build:logo": "cd packages/logo && npm run build",
        "build:test-site": "cd packages/test-site && npm run build",
        "test": "npm run package && playwright test"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.4",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.59.1",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.57.0",
        "@sveltejs/package": "^2.5.7",
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@types/node": "^25.5.2",
        "eslint": "^10.2.0",
        "eslint-plugin-svelte": "^3.17.0",
        "globals": "^17.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.1",
        "publint": "^0.3.18",
        "svelte": "^5.55.1",
        "svelte-check": "^4.4.6",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.0",
        "vite": "^8.0.7"
    }
}
